{
  "name": "medtriage",
  "version": "0.1.0",
  "private": true,
  "description": "Real-Time On-Demand Medical Triage & Telehealth Platform",
  "workspaces": [
    "client",
    "server",
    "packages/*"
  ],
  "scripts": {
    "dev": "docker compose up -d postgres redis meilisearch && npm run dev:services",
    "dev:services": "npm run dev --workspaces --if-present",
    "dev:client": "npm run dev --workspace=client",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "db:migrate": "npm run db:migrate --workspace=server",
    "db:seed": "npm run db:seed --workspace=server",
    "clean": "rm -rf node_modules client/node_modules server/node_modules packages/*/node_modules"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
