# ──────────────────────────────────────────────────
# MedTriage — Environment Variables
# Copy to .env and fill in your values
# ──────────────────────────────────────────────────

# ── General ───────────────────────────────────────
NODE_ENV=development
PORT_GATEWAY=4000
PORT_WEB=3000
PORT_AI_ENGINE=8000

# ── PostgreSQL ────────────────────────────────────
DATABASE_URL=postgresql://medtriage:medtriage_dev@localhost:5432/medtriage_db
POSTGRES_USER=medtriage
POSTGRES_PASSWORD=medtriage_dev
POSTGRES_DB=medtriage_db

# ── Redis ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Meilisearch ───────────────────────────────────
MEILISEARCH_URL=http://localhost:7700
MEILISEARCH_API_KEY=medtriage_meili_dev_key

# ── JWT Authentication ────────────────────────────
JWT_ACCESS_SECRET=your-access-secret-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-change-in-production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── AI Engine ─────────────────────────────────────
AI_ENGINE_URL=http://localhost:8000
AI_CALLBACK_BASE_URL=http://localhost:4000

# ── LLM Provider ─────────────────────────────────
# Options: openai | gemini
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-openai-key
GEMINI_API_KEY=your-gemini-key

# ── Guardrails ────────────────────────────────────
GUARDRAILS_ENABLED=true
MAX_LLM_RETRIES=3
